# ============================================================
# MeetMate — Root .gitignore
# ============================================================

# ----- Environment & secrets (NEVER commit real keys) ------
.env
.env.local
.env.*.local
.env.production

# ----- Python -----------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
eggs/
*.egg
.eggs/

# Virtual environments
venv/
.venv/
env/
ENV/
.env/

# Test & coverage output
.pytest_cache/
.coverage
htmlcov/
*.xml

# ----- Node / Next.js (covered by frontend/.gitignore too) --
node_modules/
.next/
out/
.cache/
*.tsbuildinfo

# ----- Database files ---------------------------------------
*.db
*.sqlite
*.sqlite3

# ----- Logs & debug files -----------------------------------
error_log.txt
*.log
logs/

# ----- OS & editor -------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# ----- Project-specific tooling -----------------------------
.agent/

# ----- Certificates & keys ----------------------------------
*.pem
*.key
*.crt
