# ============================================================
# MeetMate — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to version control.
# ============================================================

# ----- Database (PostgreSQL) --------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=meetmate

# Optional: override the full connection string
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/meetmate

# ----- Security (JWT) ---------------------------------------
# Generate a strong random string, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_super_secret_jwt_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ----- AI APIs (at least one LLM key is required) -----------
# Groq — used for fast transcription summarisation & task extraction
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Anthropic Claude — used for the AI chat / RAG pipeline
# Get your key at: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here

# OpenAI (optional — not currently used)
# OPENAI_API_KEY=your_openai_api_key_here

# ----- Integrations (optional) ------------------------------
# NOTION_API_KEY=your_notion_api_key_here
# TRELLO_API_KEY=your_trello_api_key_here
